# ============================================================
# Amanat Citizen Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in all CHANGE_ME values
# before running docker compose.
#
# Generate a Django secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=digital_deputat_db
POSTGRES_USER=digital_deputat_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DATABASE_URL=postgresql://digital_deputat_user:CHANGE_ME_strong_db_password@postgres:5432/digital_deputat_db

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0
REDIS_CACHE_URL=redis://:CHANGE_ME_redis_password@redis:6379/1
CELERY_BROKER_URL=redis://:CHANGE_ME_redis_password@redis:6379/2
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@redis:6379/3

# ── Django ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=amanat.settings.production
SECRET_KEY=CHANGE_ME_generate_with_python_secrets_token_urlsafe_50
DEBUG=False
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1,backend

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api
INTERNAL_API_URL=http://backend:8000
NODE_ENV=production

# ── External APIs ────────────────────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME
TELEGRAM_BOT_TOKEN=CHANGE_ME_bot_token_from_botfather

# ── Email (optional) ─────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Telegram Bot ─────────────────────────────────────────────
API_BASE_URL=http://backend:8000/api
